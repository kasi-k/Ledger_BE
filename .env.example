# Copy this file to ".env" (in the backend folder) and fill in your values.
# The .env file is loaded automatically at startup.

# --- MongoDB Atlas ---------------------------------------------------------
# Atlas → Database → Connect → Drivers → Node.js → copy the connection string.
# URL-encode any special characters in the password (e.g. @ -> %40).
# If MONGODB_URI is left unset, the app falls back to the local ledger.json file.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Optional — database name (defaults to "maarr_ledger")
MONGODB_DB=maarr_ledger

# --- Optional overrides for the existing settings --------------------------
# PORT=4100
# AUTH_USER=admin
# AUTH_PASS=maarr123
# EMP_USER=employee
# EMP_PASS=employee123
# AUTH_SECRET=change-me-in-production
